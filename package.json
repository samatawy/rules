{
    "name": "@samatawy/rules",
    "version": "0.1.0",
    "description": "TypeScript declarative rule engine and DSL utilities for parsing, validating, and executing business rules.",
    "type": "module",
    "main": "./dist/node/index.cjs",
    "module": "./dist/node/index.js",
    "types": "./dist/node/index.d.ts",
    "llms": "./llms.txt",
    "llmsFull": "https://samatawy.github.io/rules/",
    "exports": {
        ".": {
            "types": "./dist/node/index.d.ts",
            "import": "./dist/node/index.js",
            "require": "./dist/node/index.cjs"
        },
        "./browser": {
            "types": "./dist/browser/index.d.ts",
            "import": "./dist/browser/index.js",
            "require": "./dist/browser/index.cjs"
        },
        "./autocomplete": {
            "types": "./dist/autocomplete/index.d.ts",
            "import": "./dist/autocomplete/index.js",
            "require": "./dist/autocomplete/index.cjs"
        }
    },
    "files": [
        "dist",
        "llms.txt",
        "README.md",
        "LICENSE"
    ],
    "sideEffects": false,
    "publishConfig": {
        "access": "public"
    },
    "engines": {
        "node": ">=18"
    },
    "scripts": {
        "clean": "rimraf dist",
        "build": "tsup src/browser/index.ts src/autocomplete/index.ts src/node/index.ts --format esm,cjs --dts --clean",
        "postbuild": "node ./scripts/strip-dist-comments.mjs",
        "dev": "tsup src/browser/index.ts src/autocomplete/index.ts src/node/index.ts --format esm,cjs --dts --watch",
        "lint": "tsc --noEmit -p tsconfig.json",
        "test": "vitest run",
        "test:watch": "vitest",
        "docs": "typedoc",
        "prepublishOnly": "npm run lint && npm run test && npm run build"
    },
    "keywords": [
        "rules-engine",
        "business-rules",
        "decision-engine",
        "declarative",
        "dsl",
        "rete",
        "inference",
        "business-logic",
        "type-safe",
        "forward-chaining"
    ],
    "author": "Sam Atawy <sam.atawy@gmail.com>",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/samatawy/rules.git"
    },
    "bugs": {
        "url": "https://github.com/samatawy/rules/issues"
    },
    "homepage": "https://samatawy.github.io/rules/",
    "devDependencies": {
        "@types/node": "^24.3.1",
        "rimraf": "^6.0.1",
        "tsup": "^8.5.0",
        "typedoc": "^0.28.18",
        "typescript": "^5.9.2",
        "vitest": "^3.2.4"
    },
    "dependencies": {
        "json5": "^2.2.3"
    }
}